{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Altinn.Register": "Information",
      "Altinn.Register.Persistence.Leases:PostgresqlLeaseProvider": "Debug",
      "Altinn.Register.Jobs.RecurringJobHostedService": "Trace"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Warning",
        "Altinn.Register": "Information",
        "Altinn.Register.Persistence.Leases:PostgresqlLeaseProvider": "Debug",
        "Altinn.Register.Jobs.RecurringJobHostedService": "Trace"
      }
    }
  },
  "PersonLookupSettings": {
    "PersonCacheLifetimeSeconds": 3600
  },
  "Altinn": {
    "Register": {
      "RateLimit": {
        "Policy": {
          "person-lookup-failed-attempts": {
            "Limit": 10,
            "WindowDuration": "01:00:00",
            "WindowBehavior": "TrailingEdge",
            "BlockDuration": "01:00:00",
            "BlockedRequestBehavior": "Ignore"
          }
        }
      }
    }
  },
  "GeneralSettings": {
    "BridgeApiEndpoint": "https://at22.altinn.cloud/sblbridge/register/api/",
    "OpenIdWellKnownEndpoint": "https://platform.at22.altinn.cloud/authentication/api/v1/openid/",
    "JwtCookieName": "AltinnStudioRuntime"
  },
  "PlatformSettings": {
    "ApiAuthorizationEndpoint": "http://localhost:5050/authorization/api/v1/"
  },
  "Platform:SblBridge:Endpoint": "https://at22.altinn.cloud/sblbridge/"
}
